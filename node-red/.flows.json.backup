    {
        "id": "broker-local",
        "type": "mqtt-broker",
        "name": "Local MQTT",
        "broker": "localhost",
        "port": 1883,
        "clientid": "",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "5",
        "keepalive": 60,
        "cleansession": true,
        "autoUnsubscribe": true,
        "birthTopic": "",
        "birthQos": "0",
        "birthRetain": "false",
        "birthPayload": "",
        "birthMsg": {},
        "closeTopic": "",
        "closeQos": "0",
        "closeRetain": "false",
        "closePayload": "",
        "closeMsg": {},
        "willTopic": "",
        "willQos": "0",
        "willRetain": "false",
        "willPayload": "",
        "willMsg": {},
        "userProps": "",
        "sessionExpiry": ""
    },
    {
        "id": "init-inject",
        "type": "inject",
        "z": "tab-init",
        "name": "Startup",
        "props": [
            {
                "p": "payload"
            },
            {
                "p": "topic",
                "vt": "str"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 120,
        "y": 80,
        "wires": [
            [
                "init-loadlib"
            ]
        ]
    },
    {
        "id": "init-loadlib",
        "type": "function",
        "z": "tab-init",
        "name": "loadLibrary",
        "func": "const validators = {\n    rawCommand: function(payload) {\n        const VALID = ['goal', 'waypoints', 'cancel'];\n        if (!payload || typeof payload !== 'object') throw new Error('Payload must be an object');\n        if (!payload.command) throw new Error('Missing field: command');\n        if (!VALID.includes(payload.command)) throw new Error('Invalid command: ' + payload.command);\n        if (payload.command !== 'cancel' && !payload.payload) throw new Error('Missing field: payload');\n    },\n    goal: function(p) {\n        if (typeof p.x !== 'number') throw new Error('goal.x must be a number');\n        if (typeof p.y !== 'number') throw new Error('goal.y must be a number');\n        if (!p.angle || typeof p.angle !== 'object') throw new Error('goal.angle must be an object');\n        ['x', 'y', 'z'].forEach(function(k) {\n            if (typeof p.angle[k] !== 'number') throw new Error('goal.angle.' + k + ' must be a number');\n        });\n    },\n    waypoints: function(p) {\n        if (!Array.isArray(p.waypoints)) throw new Error('waypoints must be an array');\n        if (p.waypoints.length === 0) throw new Error('waypoints array must not be empty');\n        p.waypoints.forEach(function(wp, i) {\n            if (typeof wp.id !== 'number') throw new Error('waypoints[' + i + '].id must be a number');\n            if (typeof wp.label !== 'string') throw new Error('waypoints[' + i + '].label must be a string');\n            if (typeof wp.x !== 'number') throw new Error('waypoints[' + i + '].x must be a number');\n            if (typeof wp.y !== 'number') throw new Error('waypoints[' + i + '].y must be a number');\n            if (!wp.angle || typeof wp.angle !== 'object') throw new Error('waypoints[' + i + '].angle must be an object');\n        });\n    }\n};\n\nconst transformers = {\n    goal: function(p) {\n        return { x: p.x, y: p.y, angle: { x: p.angle.x, y: p.angle.y, z: p.angle.z } };\n    },\n    waypoints: function(p) {\n        return { waypoints: p.waypoints };\n    },\n    cancel: function() {\n        return {};\n    }\n};\n\nconst errors = {\n    wrap: function(err, source) {\n        return {\n            timestamp: new Date().toISOString(),\n            error_type: 'VALIDATION_ERROR',\n            message: err.message || String(err),\n            source: source || 'node-red'\n        };\n    }\n};\n\nglobal.set('lib', { validators: validators, transformers: transformers, errors: errors });\nnode.status({ fill: 'green', shape: 'dot', text: 'Library loaded' });\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 80,
        "wires": [
            []
        ]
    },
    {
        "id": "cmd-in-raw",
        "type": "mqtt in",
        "z": "tab-cmd",
        "name": "amr/cmd/raw",
        "topic": "amr/cmd/raw",
        "qos": "2",
        "datatype": "json",
        "broker": "broker-local",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 120,
        "y": 140,
        "wires": [
            [
                "cmd-validate"
            ]
        ]
    },
    {
        "id": "cmd-validate",
        "type": "function",
        "z": "tab-cmd",
        "name": "validateRaw",
        "func": "var lib = global.get('lib');\ntry {\n    lib.validators.rawCommand(msg.payload);\n    msg.command = msg.payload.command;\n    msg.cmdPayload = msg.payload.payload || {};\n    return [msg, null];\n} catch (e) {\n    var errMsg = { payload: lib.errors.wrap(e, 'validateRaw') };\n    node.error(e.message, msg);\n    return [null, errMsg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 140,
        "wires": [
            [
                "cmd-switch"
            ],
            [
                "cmd-debug-err"
            ]
        ]
    },
    {
        "id": "cmd-switch",
        "type": "switch",
        "z": "tab-cmd",
        "name": "Route by command",
        "property": "command",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "goal",
                "vt": "str"
            },
            {
                "t": "eq",
                "v": "waypoints",
                "vt": "str"
            },
            {
                "t": "eq",
                "v": "cancel",
                "vt": "str"
            }
        ],
        "checkall": "false",
        "repair": false,
        "outputs": 3,
        "x": 530,
        "y": 140,
        "wires": [
            [
                "cmd-goal-tx"
            ],
            [
                "cmd-wp-tx"
            ],
            [
                "cmd-cancel-tx"
            ]
        ]
    },
    {
        "id": "cmd-goal-tx",
        "type": "function",
        "z": "tab-cmd",
        "name": "transformGoal",
        "func": "var lib = global.get('lib');\ntry {\n    lib.validators.goal(msg.cmdPayload);\n    msg.payload = lib.transformers.goal(msg.cmdPayload);\n    msg.topic = 'amr/cmd/goal';\n    msg.qos = 1;\n    return [msg, null];\n} catch (e) {\n    var errMsg = { payload: lib.errors.wrap(e, 'transformGoal') };\n    node.error(e.message, msg);\n    return [null, errMsg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 80,
        "wires": [
            [
                "cmd-out-goal"
            ],
            [
                "cmd-debug-err"
            ]
        ]
    },
    {
        "id": "cmd-wp-tx",
        "type": "function",
        "z": "tab-cmd",
        "name": "transformWaypoints",
        "func": "var lib = global.get('lib');\ntry {\n    lib.validators.waypoints(msg.cmdPayload);\n    msg.payload = lib.transformers.waypoints(msg.cmdPayload);\n    msg.topic = 'amr/cmd/waypoints';\n    msg.qos = 1;\n    return [msg, null];\n} catch (e) {\n    var errMsg = { payload: lib.errors.wrap(e, 'transformWaypoints') };\n    node.error(e.message, msg);\n    return [null, errMsg];\n}",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 140,
        "wires": [
            [
                "cmd-out-wp"
            ],
            [
                "cmd-debug-err"
            ]
        ]
    },
    {
        "id": "cmd-cancel-tx",
        "type": "function",
        "z": "tab-cmd",
        "name": "transformCancel",
        "func": "var lib = global.get('lib');\nmsg.payload = lib.transformers.cancel();\nmsg.topic = 'amr/cmd/cancel';\nmsg.qos = 1;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 200,
        "wires": [
            [
                "cmd-out-cancel"
            ]
        ]
    },
