    {
        "id": "state-fn-odom",
        "type": "function",
        "z": "tab-state",
        "name": "handleOdom",
        "func": "var p = msg.payload;\nif (!p || !p.position || !p.timestamp) {\n    node.error('Invalid odom payload', msg);\n    return null;\n}\nnode.status({ fill: 'green', shape: 'dot', text: 'x:' + p.position.x.toFixed(2) + ' y:' + p.position.y.toFixed(2) + ' [' + p.trigger + ']' });\n// TODO: INSERT INTO odom\nreturn msg;",
