        "func": "var p = msg.payload;\nif (!p || typeof p.level_pct !== 'number') {\n    node.error('Invalid battery payload', msg);\n    return null;\n}\nvar fill = p.level_pct > 50 ? 'green' : p.level_pct > 20 ? 'yellow' : 'red';\nnode.status({ fill: fill, shape: 'dot', text: p.level_pct.toFixed(0) + '% ' + (p.charging ? '[charging]' : '') });\n// TODO: INSERT INTO health_battery\nreturn msg;",
