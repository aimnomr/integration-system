                "audit-fn-ia"
            ]
        ]
    },
    {
        "id": "audit-fn-ia",
        "type": "function",
        "z": "tab-audit",
        "name": "tagInstantActions",
        "func": "var m = msg.payload;\nif (!m || typeof m.serialNumber !== 'string' || !Array.isArray(m.actions)) {\n    node.error('Invalid instantActions message', msg);\n    return null;\n}\nvar types = m.actions.map(function (a) { return a.actionType; }).join(',');\nnode.status({ fill: 'blue', shape: 'dot', text: m.serialNumber + ' ' + types });\nmsg.headers = { 'content-type': 'application/json' };\nmsg.payload = { kind: 'instantActions', message: m };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 200,
        "wires": [
            [
                "audit-http-ia"
            ]
        ]
    },
    {
        "id": "audit-http-ia",
        "type": "http request",
        "z": "tab-audit",
        "name": "POST /ingest/command",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:8000/ingest/command",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
