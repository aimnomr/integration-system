    {
        "id": "oee-in-cycle",
        "type": "mqtt in",
        "z": "tab-oee",
        "name": "amr/oee/cycle",
        "topic": "amr/oee/cycle",
        "qos": "1",
        "datatype": "json",
        "broker": "broker-local",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 120,
        "y": 80,
        "wires": [
            [
                "oee-fn-cycle"
            ]
        ]
    },
    {
        "id": "oee-fn-cycle",
        "type": "function",
        "z": "tab-oee",
        "name": "handleCycle",
        "func": "var p = msg.payload;\nif (!p || !p.trip_id || !p.result) {\n    node.error('Invalid OEE cycle payload', msg);\n    return null;\n}\nvar fill = p.result === 'SUCCEEDED' ? 'green' : 'red';\nnode.status({ fill: fill, shape: 'dot', text: p.trip_id + ': ' + p.result + ' (' + p.duration_s.toFixed(1) + 's)' });\n// TODO: INSERT INTO oee_cycle\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 80,
        "wires": [
            [
                "oee-dbg-cycle"
            ]
        ]
    },
    {
        "id": "oee-dbg-cycle",
        "type": "debug",
        "z": "tab-oee",
        "name": "oee/cycle",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 510,
        "y": 80,
        "wires": []
    },
