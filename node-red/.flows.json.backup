        "name": "handleNavStatus",
        "func": "var p = msg.payload;\nif (!p || !p.status) {\n    node.error('Invalid nav status payload', msg);\n    return null;\n}\nvar fillMap = { NAVIGATING: 'blue', SUCCEEDED: 'green', ABORTED: 'red', PREEMPTED: 'yellow', IDLE: 'grey' };\nnode.status({ fill: fillMap[p.status] || 'grey', shape: 'dot', text: p.status });\n// TODO: INSERT INTO nav_status\nreturn msg;",
