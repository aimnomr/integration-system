        "func": "var p = msg.payload;\nif (!p || !p.error_type) {\n    node.error('Invalid error payload', msg);\n    return null;\n}\nnode.status({ fill: 'red', shape: 'ring', text: p.error_type + ': ' + p.message });\nnode.error('[' + p.source + '] ' + p.error_type + ': ' + p.message, msg);\n// TODO: INSERT INTO health_error\nreturn msg;",
