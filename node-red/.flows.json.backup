[
    {
        "id": "tab-ingest",
        "type": "tab",
        "label": "Telemetry Ingestion",
        "disabled": false,
        "info": "Subscribes the VDA5050 `state` and `connection` topics (amr/v2/+/+/...) for every robot and persists each message by POSTing it to the FastAPI ingestion API, which writes to PostgreSQL.",
        "env": []
    },
    {
        "id": "tab-audit",
        "type": "tab",
        "label": "Command Audit",
        "disabled": false,
        "info": "Passive tap on the VDA5050 `order` and `instantActions` topics. Logs every command to PostgreSQL via the FastAPI ingestion API. Sits parallel to the command path — it cannot block or delay delivery to the robot.",
        "env": []
    },
    {
        "id": "tab-oee",
        "type": "tab",
        "label": "OEE",
        "disabled": false,
        "info": "Derives OEE trip cycles from order-completion transitions observed in the VDA5050 `state` stream. A cycle is emitted when an active order's nodeStates empties (SUCCEEDED) or its orderId clears mid-order (ABORTED).",
        "env": []
    },
    {
        "id": "tab-test",
        "type": "tab",
        "label": "Test Harness",
        "disabled": false,
        "info": "Manual VDA5050 message injectors for amr001. Click an inject to publish an `order` or `instantActions` message straight to the robot's MQTT topic, skipping FastAPI. Outbound `state`/`connection` are shown on the right."
    },
    {
        "id": "broker-local",
        "type": "mqtt-broker",
        "name": "Local MQTT",
        "broker": "localhost",
        "port": 1883,
        "clientid": "",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "5",
        "keepalive": 60,
        "cleansession": true,
        "autoUnsubscribe": true,
        "birthTopic": "",
        "birthQos": "0",
        "birthRetain": "false",
        "birthPayload": "",
        "birthMsg": {},
        "closeTopic": "",
        "closeQos": "0",
        "closeRetain": "false",
        "closePayload": "",
        "closeMsg": {},
        "willTopic": "",
        "willQos": "0",
        "willRetain": "false",
        "willPayload": "",
        "willMsg": {},
        "userProps": "",
        "sessionExpiry": ""
    },
    {
        "id": "ingest-in-state",
        "type": "mqtt in",
        "z": "tab-ingest",
        "name": "amr/v2/+/+/state",
        "topic": "amr/v2/+/+/state",
        "qos": "0",
        "datatype": "json",
        "broker": "broker-local",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 150,
        "y": 100,
        "wires": [
            [
                "ingest-fn-state"
            ]
        ]
    },
    {
        "id": "ingest-fn-state",
        "type": "function",
        "z": "tab-ingest",
        "name": "validateState",
        "func": "var s = msg.payload;\nif (!s || typeof s.serialNumber !== 'string' || !s.timestamp) {\n    node.error('Invalid VDA5050 state message', msg);\n    return null;\n}\nvar pos = s.agvPosition || {};\nnode.status({ fill: 'green', shape: 'dot', text: s.serialNumber + ' x:' + (pos.x || 0).toFixed(2) + ' y:' + (pos.y || 0).toFixed(2) });\nmsg.headers = { 'content-type': 'application/json' };\nmsg.payload = s;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 100,
        "wires": [
            [
                "ingest-http-state"
            ]
        ]
    },
    {
        "id": "ingest-http-state",
        "type": "http request",
        "z": "tab-ingest",
        "name": "POST /ingest/state",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:8000/ingest/state",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 620,
        "y": 100,
        "wires": [
            [
                "ingest-dbg-state"
            ]
        ]
    },
    {
        "id": "ingest-dbg-state",
        "type": "debug",
        "z": "tab-ingest",
        "name": "state persisted",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 850,
        "y": 100,
        "wires": []
    },
    {
        "id": "ingest-in-conn",
        "type": "mqtt in",
        "z": "tab-ingest",
        "name": "amr/v2/+/+/connection",
        "topic": "amr/v2/+/+/connection",
        "qos": "1",
        "datatype": "json",
        "broker": "broker-local",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
        "y": 200,
        "wires": [
            [
                "ingest-fn-conn"
            ]
        ]
    },
    {
        "id": "ingest-fn-conn",
        "type": "function",
        "z": "tab-ingest",
        "name": "validateConnection",
        "func": "var c = msg.payload;\nvar VALID = ['ONLINE', 'OFFLINE', 'CONNECTIONBROKEN'];\nif (!c || typeof c.serialNumber !== 'string' || VALID.indexOf(c.connectionState) === -1) {\n    node.error('Invalid VDA5050 connection message', msg);\n    return null;\n}\nvar fill = c.connectionState === 'ONLINE' ? 'green' : c.connectionState === 'OFFLINE' ? 'grey' : 'red';\nnode.status({ fill: fill, shape: 'dot', text: c.serialNumber + ': ' + c.connectionState });\nmsg.headers = { 'content-type': 'application/json' };\nmsg.payload = c;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 200,
        "wires": [
            [
                "ingest-http-conn"
            ]
        ]
    },
    {
        "id": "ingest-http-conn",
        "type": "http request",
        "z": "tab-ingest",
        "name": "POST /ingest/connection",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://localhost:8000/ingest/connection",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
