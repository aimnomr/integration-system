# Frontend environment variables. Copy to .env.local for development.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# REST base URL — points to FastAPI. In dev the Vite proxy rewrites /api/*
# to this target, so you can leave it at the default.
VITE_API_URL=http://localhost:8000

# MQTT WebSocket listener on Mosquitto (configured in mosquitto/mosquitto.conf).
VITE_MQTT_WS_URL=ws://localhost:9001

# API key — leave blank for local dev (FastAPI is open by default). When the
# backend's API_KEY is set, fill this in and every request will carry
# X-API-Key automatically.
VITE_API_KEY=

# Branding overrides (optional — empty means use the defaults in src/branding).
# VITE_APP_NAME=AMR Console
