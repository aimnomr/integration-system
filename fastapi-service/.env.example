# FastAPI FMS gateway — environment variables.
# Copy this file to .env and adjust. Startup validation (app/config.py) checks
# the required vars and fails fast with a clear message if any are missing.

# --- MQTT (required — no default) ---
MQTT_BROKER=localhost
MQTT_PORT=1883

# --- PostgreSQL (optional — db.py uses these defaults if unset) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amr_integration
DB_USER=postgres
DB_PASSWORD=admin

# Connection-pool size (G16). The pool is built lazily on first query.
DB_POOL_MIN=1
DB_POOL_MAX=10

# --- Telemetry retention (optional — G19) ---
# A background task prunes state_snapshots + connection_log older than this
# many days (child tables cascade). 0 disables pruning.
TELEMETRY_RETENTION_DAYS=30

# --- Node-RED (optional) ---
# HTTP URL probed by GET /system/status for Node-RED liveness.
NODE_RED_URL=http://localhost:1880

# --- Authentication (optional — G10) ---
# If set, the client-facing API requires a matching X-API-Key header. Leave it
# unset (the default) to keep the API open for local development. When set, also
# set API_KEY in ros-bridge-service/.env so GET /fleet still works.
# API_KEY=change-me

# --- Rate limiting (optional — G11) ---
# Max requests per client IP per 60 s window; 0 disables the limiter.
RATE_LIMIT_PER_MINUTE=120

# --- CORS (optional — G18) ---
# Comma-separated list of origins allowed to call the API from a browser.
# Default covers the Vite dev server. Add your production frontend URL when
# deploying (e.g. https://amr.example.com).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
