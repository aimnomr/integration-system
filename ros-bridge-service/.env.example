# ROS Bridge Service — environment variables.
# Copy this file to .env and adjust. index.js fails fast if a required var is missing.

# --- MQTT (required — no default) ---
MQTT_BROKER=mqtt://localhost:1883

# --- Fleet config (optional — default shown) ---
# The ROS Bridge fetches its fleet definition from FastAPI's GET /fleet at startup.
# The database is the single source of truth; FastAPI is its gateway.
FLEET_API_URL=http://localhost:8000/fleet

# --- ROS topic overrides (optional — defaults shown) ---
NAV_GOAL_TOPIC=/move_base_simple/goal
CANCEL_TOPIC=/move_base/cancel

# --- Authentication (optional — G10) ---
# Set this only if FastAPI's API_KEY is set; it is sent as X-API-Key on GET /fleet.
# API_KEY=change-me

# --- Logging (optional — defaults to info) ---
# LOG_LEVEL=info
