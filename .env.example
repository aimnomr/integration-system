# ─────────────────────────────────────────────────────────────────────────
# AMR Integration System — per-device configuration.
#
# Copy this file to `.env` (same folder) and edit for your machine:
#     cp .env.example .env
#
# docker compose auto-loads `.env` and substitutes ${VAR} into
# docker-compose.yml. Every var has a default baked into the compose file, so
# you only need to set the ones that differ from a same-machine localhost run.
# ─────────────────────────────────────────────────────────────────────────

# ── Client access ────────────────────────────────────────────────────────
# The address that BROWSERS and PHONES use to reach this machine.
#   • Stack + browser on the SAME machine .......... localhost
#   • Access from phones / other PCs on the LAN .... this machine's LAN IP
#                                                    (find with `ipconfig`),
#                                                    e.g. 192.168.1.50
# IMPORTANT: this is inlined into the frontend at BUILD time. After changing
# it you must rebuild:  docker compose up --build -d frontend
PUBLIC_HOST=localhost

# ── Published host ports ──────────────────────────────────────────────────
# Change only if these ports clash with something else on the host.
API_PORT=8000
FRONTEND_PORT=5173
MQTT_WS_PORT=9001
MQTT_TCP_PORT=1883
NODE_RED_PORT=1880
POSTGRES_PORT=5432

# ── Database ──────────────────────────────────────────────────────────────
# NOTE: POSTGRES_PASSWORD only takes effect on a FRESH volume. If you change it
# on an existing deployment, also `docker compose down -v` (wipes all data) or
# change the role's password inside Postgres manually.
POSTGRES_DB=amr_integration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin

# ── Auth ──────────────────────────────────────────────────────────────────
# Blank = open API (no key needed). Set a value to require the X-API-Key header
# on client endpoints; the frontend and ros-bridge pick it up automatically.
# Recommended when the stack is reachable from an untrusted network.
API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Robot reachability (container → robot's rosbridge) ────────────────────
# How the ros-bridge CONTAINER reaches the robot's rosbridge websocket.
#   • Robot/sim runs on THIS machine (the Docker host) ... host.docker.internal
#     (the DB seeds the robot URL as ws://127.0.0.1:9090; the container rewrites
#      that loopback host to the value below)
#   • Robot is a SEPARATE machine with a real IP ......... leave BLANK, and set
#     the robot's rosbridge_url in the database to ws://<robot-ip>:9090
ROSBRIDGE_HOST_OVERRIDE=host.docker.internal
